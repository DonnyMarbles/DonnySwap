#
# Frontend / Vite environment variables.
# Copy to `.env` in the repo root and adjust as needed.
#

# Base URL used by apiUrl() helpers inside the React app.
# Example: https://donnyswap.xyz/api
VITE_API_BASE_URL='http://localhost:3002/api'

# Vite dev-server proxy target for /api calls when running `npm run dev`.
VITE_PROXY_API_TARGET='http://localhost:3002'

# Optional prefix appended when proxying (keeps default `/api` when blank).
VITE_PROXY_API_PREFIX='/api'

