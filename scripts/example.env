#
# Environment variables for scripts within `scripts/`.
# Copy to `scripts/.env` (or export in your shell) before running any script.
#

# --- Fees listener (scripts/feesListener.js) ---
FEE_LISTENER_RPC_URL='https://peaq.betterfuturelabs.xyz'
FEE_MANAGER_ADDRESS='0x0000000000000000000000000000000000000000'
FEE_MANAGER_OWNER_KEY=''      # Private key used if MNEMONIC is unset
MNEMONIC=''                   # 12/24-word phrase (takes precedence over key)
FEE_LISTENER_API_BASE_URL='http://localhost:3002'
FEE_LISTENER_CHAIN_ID='3338'
FEES_LISTENER_INTERVAL_MS='14400000'  # 4 hours

# --- Database access (scripts/purgeFees.js or other maintenance tasks) ---
PGUSER=''
PGPASSWORD=''
PGHOST=''
PGDATABASE=''
PGPORT='5432'
PGSSL='require'
DATABASE_URL=''               # Optional single connection string

